# MongoDB Connection
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=

# Auth.js Secret
AUTH_SECRET=

# App Base URL
AUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI Service - Groq API
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=
