{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run tests/integration",
    "test:api": "vitest run tests/integration/api",
    "test:e2e": "LD_LIBRARY_PATH=/tmp/playwright-libs/all playwright test",
    "test:e2e:chromium": "LD_LIBRARY_PATH=/tmp/playwright-libs/all playwright test --project=chromium",
    "test:e2e:firefox": "LD_LIBRARY_PATH=/tmp/playwright-libs/all playwright test --project=firefox",
    "test:e2e:webkit": "LD_LIBRARY_PATH=/tmp/playwright-libs/all playwright test --project=webkit",
    "test:e2e:mobile": "LD_LIBRARY_PATH=/tmp/playwright-libs/all playwright test --project=mobile-chrome --project=mobile-safari",
    "test:e2e:debug": "LD_LIBRARY_PATH=/tmp/playwright-libs/all playwright test --debug",
    "test:e2e:report": "playwright show-report tests/e2e/reports/html",
    "test:e2e:visual": "LD_LIBRARY_PATH=/tmp/playwright-libs/all playwright test tests/e2e/responsive/visual-regression.spec.ts"
  },
  "dependencies": {
    "@auth/mongodb-adapter": "^3.11.2",
    "@base-ui/react": "^1.6.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^1.24.0",
    "mongodb": "^6.21.0",
    "next": "16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-use-measure": "^2.1.7",
    "recharts": "^3.9.2",
    "shadcn": "^4.13.0",
    "svg-dotted-map": "^2.0.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "mongodb-memory-server": "^11.2.0",
    "msw": "^2.15.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
